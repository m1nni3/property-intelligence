{
  "name": "property-intelligence",
  "version": "0.1.0",
  "type": "module",
  "description": "Property Intelligence Platform — Node API + SQLite + Vite frontend (Cloudflare Workers/D1/R2 for production)",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite --clearScreen false\" \"node server/index.js\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --clearScreen false",
    "build": "rm -rf dist && mkdir -p dist/src/components dist/src/pages && npx @tailwindcss/cli -i src/style.css -o dist/src/style.css && cp production/*.html dist/ && cp src/api.js dist/src/ && cp src/components/*.js dist/src/components/ && cp src/pages/*.js dist/src/pages/",
    "deploy": "npm run build && wrangler deploy",
    "db:init": "node server/init-db.js",
    "lint": "eslint src/ server/",
    "lint:fix": "eslint src/ server/ --fix",
    "format": "prettier --write src/ server/",
    "format:check": "prettier --check src/ server/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.20260601.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.5",
    "sass": "^1.101.0",
    "terser": "^5.48.0",
    "typescript": "^5.8.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.105.0",
    "@tailwindcss/cli": "^4.3.1"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4.3.0",
    "tesseract.js": "^7.0.0"
  }
}
