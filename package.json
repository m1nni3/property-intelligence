{
  "name": "property-intelligence",
  "version": "0.1.0",
  "type": "module",
  "description": "Property Intelligence Platform — Vite frontend + Cloudflare Workers/D1/R2 backend",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite --clearScreen false\" \"node server/index.js\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --clearScreen false",
    "build": "vite build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/ worker/src/",
    "format:check": "prettier --check src/ worker/src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "predeploy": "npm run lint && npm run typecheck && npm run test",
    "deploy": "npm run predeploy && npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.20260601.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^26.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "sass": "^1.101.0",
    "terser": "^5.48.0",
    "typescript": "^5.8.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.105.0"
  },
  "dependencies": {
    "tailwindcss": "^4.3.0"
  }
}
